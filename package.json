{
  "name": "project-brain",
  "displayName": "Project Brain",
  "description": "Generate AI-native project context files for Claude, Cursor, Copilot & more",
  "version": "3.0.1",
  "license": "MIT",
  "publisher": "ProjectBrainDefined",
  "icon": "assets/icon.png",
  "homepage": "https://github.com/malikmuhammadsaadshafiq-dev/project-brain#readme",
  "bugs": {
    "url": "https://github.com/malikmuhammadsaadshafiq-dev/project-brain/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/malikmuhammadsaadshafiq-dev/project-brain"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "ai",
    "claude",
    "cursor",
    "copilot",
    "context",
    "documentation",
    "codebase",
    "analyzer",
    "dashboard"
  ],
  "activationEvents": [
    "onCommand:projectBrain.init",
    "onCommand:projectBrain.quickInit",
    "onCommand:projectBrain.deepScan",
    "onCommand:projectBrain.dashboard",
    "onCommand:projectBrain.copyContext",
    "onView:projectBrainTree"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "projectBrain.init",
        "title": "Project Brain: Initialize",
        "icon": "$(add)"
      },
      {
        "command": "projectBrain.quickInit",
        "title": "Project Brain: Quick Initialize (Auto-detect)",
        "icon": "$(zap)"
      },
      {
        "command": "projectBrain.deepScan",
        "title": "Project Brain: Deep Scan Codebase",
        "icon": "$(search)"
      },
      {
        "command": "projectBrain.dashboard",
        "title": "Project Brain: Open Health Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "projectBrain.copyContext",
        "title": "Project Brain: Copy Smart Context to Clipboard",
        "icon": "$(clippy)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projectBrainView",
          "title": "Project Brain",
          "icon": "assets/brain-icon.svg"
        }
      ]
    },
    "views": {
      "projectBrainView": [
        {
          "id": "projectBrainTree",
          "name": "Brain Files"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.0.0"
  }
}