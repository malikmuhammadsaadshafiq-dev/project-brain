{
  "name": "project-brain",
  "displayName": "Project Brain",
  "description": "Generate AI-native project context files for Claude, Cursor, Copilot & more",
  "version": "2.0.0",
  "publisher": "ProjectBrain",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/malikmuhammadsaadshafiq-dev/project-brain"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "cursor",
    "copilot",
    "context",
    "documentation"
  ],
  "activationEvents": [
    "onCommand:projectBrain.init",
    "onCommand:projectBrain.quickInit",
    "onView:projectBrainTree"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "projectBrain.init",
        "title": "Project Brain: Initialize"
      },
      {
        "command": "projectBrain.quickInit",
        "title": "Project Brain: Quick Initialize (Auto-detect)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "projectBrainView",
          "title": "Project Brain",
          "icon": "assets/brain-icon.svg"
        }
      ]
    },
    "views": {
      "projectBrainView": [
        {
          "id": "projectBrainTree",
          "name": "Brain Files"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  }
}